# コピーして .env.local を作成し、各値を埋めてください。
# Phase 0 完了後・Phase 1 開始前に Supabase / Lark の値を設定する必要があります。

# ── Supabase ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── アプリ ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Lark（App ID / App Secret は env のみ。DB に保存しない／Lark Rules §6） ──
LARK_APP_ID=
LARK_APP_SECRET=
LARK_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/lark/callback
LARK_WEBHOOK_VERIFY_TOKEN=
